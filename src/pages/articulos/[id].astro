---
import { posts, catColor } from '../../data/posts';

export function getStaticPaths() {
  return posts.map(post => ({
    params: { id: String(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const color = catColor[post.category] ?? '#555';
const otherPosts = posts.filter(p => p.id !== post.id).slice(0, 3);
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.title} — EAAF</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Saira+Condensed:wght@400;500;600;700;800&family=Roboto:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Roboto', sans-serif; color: #1D1D1B; background: #fff; }
    h1, h2, h3, h4 { font-family: 'Saira Condensed', sans-serif; text-transform: uppercase; }
    a { text-decoration: none; color: inherit; }
    .article-body p  { font-size: 17px; color: #3a3a3a; line-height: 1.85; margin-bottom: 22px; font-weight: 300; }
    .article-body h3 { font-family: 'Saira Condensed', sans-serif; text-transform: uppercase; font-size: 22px; font-weight: 700; color: #1D1D1B; margin: 40px 0 14px; letter-spacing: 0.04em; }
    .article-body blockquote { border-left: 4px solid #E2064A; padding: 18px 28px; margin: 32px 0; background: #F8F8F8; }
    .article-body blockquote p { font-size: 16px; font-style: italic; color: #54595F; margin: 0; line-height: 1.7; }
    .article-body ul { list-style: none; padding: 0; margin-bottom: 22px; }
    .article-body ul li { display: flex; gap: 12px; font-size: 16px; color: #3a3a3a; line-height: 1.7; margin-bottom: 10px; font-weight: 300; }
    .article-body ul li::before { content: "—"; color: #E2064A; font-weight: 700; flex-shrink: 0; }
    .article-body strong { font-weight: 700; color: #1D1D1B; }
    .card:hover { border-color: #E2064A !important; }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav style="background:#1D1D1B; padding:14px 24px; display:flex; align-items:center; justify-content:space-between;">
    <div style="display:flex; align-items:center; gap:16px;">
      <a href="/blog" style="display:flex; align-items:center; gap:8px; color:#7A7A7A;">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        <span style="font-family:'Saira Condensed',sans-serif; font-size:12px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;">Volver a Novedades</span>
      </a>
    </div>
    <a href="https://eaaf.org/donacion-eaaf/" target="_blank" rel="noopener"
      style="font-family:'Saira Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#E2064A; background:#fff; padding:8px 18px; display:inline-block;">
      DONACIÓN
    </a>
  </nav>

  <!-- HERO DEL ARTÍCULO -->
  <header style="background:#1D1D1B; padding:56px 24px 64px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:24px;">
        <span style={`font-family:'Saira Condensed',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:${color}; border-left:3px solid ${color}; padding-left:8px;`}>{post.category}</span>
        <span style="font-family:'Roboto',sans-serif; font-size:13px; color:#7A7A7A;">{post.read} de lectura</span>
      </div>
      <h1 style="font-size:clamp(28px,4.5vw,54px); font-weight:800; color:#fff; line-height:1.05; margin-bottom:24px; letter-spacing:0.01em;">{post.title}</h1>
      <p style="font-family:'Roboto',sans-serif; font-size:18px; color:#ADADAD; line-height:1.65; max-width:640px; font-weight:300; margin-bottom:32px;">{post.excerpt}</p>
      <div style="display:flex; align-items:center; gap:16px; padding-top:24px; border-top:1px solid #333;">
        <div>
          <p style="font-family:'Saira Condensed',sans-serif; font-size:14px; font-weight:700; color:#fff; letter-spacing:0.05em;">{post.author}</p>
          <p style="font-family:'Roboto',sans-serif; font-size:13px; color:#7A7A7A; margin-top:2px;">{post.date}</p>
        </div>
      </div>
    </div>
  </header>

  <!-- CUERPO DEL ARTÍCULO -->
  <article style="max-width:800px; margin:0 auto; padding:64px 24px 80px;">
    <div class="article-body">
      <Fragment set:html={post.body} />
    </div>

    <!-- CTA INFERIOR -->
    <div style="margin-top:64px; background:#E2064A; padding:40px; text-align:center;">
      <p style="font-family:'Saira Condensed',sans-serif; font-size:12px; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:12px;">EAAF — INICIATIVA DE IDENTIFICACIÓN</p>
      <h2 style="font-size:clamp(22px,3vw,36px); font-weight:800; color:#fff; margin-bottom:16px; line-height:1.1;">¿TODAVÍA NO DISTE TU MUESTRA?</h2>
      <p style="font-family:'Roboto',sans-serif; font-size:15px; color:rgba(255,255,255,0.85); line-height:1.65; margin-bottom:28px; font-weight:300;">Llamá al 0800 345 3236 (gratuito) o escribí a iniciativa@eaaf.org. Sin costo, sin trámites complicados.</p>
      <a href="mailto:iniciativa@eaaf.org"
        style="font-family:'Saira Condensed',sans-serif; font-size:15px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#E2064A; background:#fff; padding:14px 32px; display:inline-block;">
        CONTACTAR AL EAAF
      </a>
    </div>
  </article>

  <!-- OTROS ARTÍCULOS -->
  <section style="background:#F8F8F8; padding:56px 24px 72px;">
    <div style="max-width:1100px; margin:0 auto;">
      <p style="font-family:'Saira Condensed',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:#ADADAD; margin-bottom:28px; display:flex; align-items:center; gap:12px;">
        <span style="width:32px; height:2px; background:#E2064A; display:inline-block;"></span>
        MÁS ARTÍCULOS
      </p>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:1px; background:#E3E3E3;">
        {otherPosts.map(p => (
          <a href={`/articulos/${p.id}`} class="card" style="background:#fff; padding:28px; display:flex; flex-direction:column; border-top:3px solid transparent; transition:border-color 0.15s;">
            <span style={`font-family:'Saira Condensed',sans-serif; font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:${catColor[p.category]??'#555'}; border-left:3px solid ${catColor[p.category]??'#555'}; padding-left:8px; margin-bottom:12px; display:block;`}>{p.category}</span>
            <h3 style="font-size:15px; font-weight:700; color:#1D1D1B; line-height:1.3; margin-bottom:10px; letter-spacing:0.02em; flex:1;">{p.title}</h3>
            <p style="font-family:'Roboto',sans-serif; font-size:12px; color:#ADADAD; margin-top:auto; padding-top:12px; border-top:1px solid #F0F0F0;">{p.date} · {p.read}</p>
          </a>
        ))}
      </div>
      <div style="margin-top:28px; text-align:center;">
        <a href="/blog" style="font-family:'Saira Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#E2064A; border:1.5px solid #E2064A; padding:12px 28px; display:inline-block;">
          VER TODOS LOS ARTÍCULOS
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer style="background:#E2064A; padding:32px 24px;">
    <div style="max-width:1100px; margin:0 auto; display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:16px;">
      <div style="display:flex; align-items:center; gap:16px;">
        <div style="border:2px solid rgba(255,255,255,0.6); padding:4px 8px;">
          <span style="font-family:'Saira Condensed',sans-serif; font-size:18px; font-weight:800; color:#fff; letter-spacing:0.08em;">EAAF</span>
        </div>
        <p style="font-family:'Roboto',sans-serif; font-size:12px; color:rgba(255,255,255,0.7);">0800 345 3236 · iniciativa@eaaf.org</p>
      </div>
      <p style="font-family:'Roboto',sans-serif; font-size:12px; color:rgba(255,255,255,0.5);">© 2026 EAAF · Sección institucional con fines académicos</p>
    </div>
  </footer>

</body>
</html>

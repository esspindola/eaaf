---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EAAF — Iniciá la búsqueda de tu familiar</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Saira+Condensed:wght@400;500;600;700;800&family=Roboto:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Roboto', sans-serif; color: #1D1D1B; background: #fff; }
    h1, h2, h3, h4 { font-family: 'Saira Condensed', sans-serif; text-transform: uppercase; }
    input, select, textarea, button { font-family: 'Roboto', sans-serif; }
    input:focus, select:focus, textarea:focus { outline: 2px solid #E2064A; outline-offset: -1px; }
    a { color: inherit; }
  </style>
</head>
<body>

  <!-- ▸ HERO ROJO — branding + titular -->
  <section style="background:#E2064A; padding:32px 24px 64px;">
    <div style="max-width:1100px; margin:0 auto;">

      <!-- Logo row -->
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:64px;">
        <div style="display:flex; align-items:center; gap:16px;">
          <div style="border:2px solid rgba(255,255,255,0.6); padding:6px 10px;">
            <span style="font-family:'Saira Condensed',sans-serif; font-size:22px; font-weight:800; color:#fff; letter-spacing:0.08em;">EAAF</span>
          </div>
          <div style="border-left:1px solid rgba(255,255,255,0.4); padding-left:16px;">
            <p style="font-family:'Roboto',sans-serif; font-size:12px; color:rgba(255,255,255,0.85); line-height:1.3; font-weight:300;">Equipo Argentino de<br/>Antropología Forense</p>
          </div>
        </div>
        <a href="https://eaaf.org/donacion-eaaf/" target="_blank" rel="noopener"
          style="font-family:'Saira Condensed',sans-serif; font-size:15px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#E2064A; background:#fff; padding:10px 24px; text-decoration:none; display:inline-block;">
          DONACIÓN
        </a>
      </div>

      <!-- Titular -->
      <div style="max-width:720px;">
        <p style="font-family:'Saira Condensed',sans-serif; font-size:13px; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:16px;">
          Para familias de personas desaparecidas
        </p>
        <h1 style="font-size:clamp(44px,7vw,80px); font-weight:800; color:#fff; line-height:0.95; margin-bottom:24px; letter-spacing:-0.01em;">
          Buscamos e<br/>identificamos a<br/>personas desaparecidas.
        </h1>
        <p style="font-family:'Roboto',sans-serif; font-size:18px; color:rgba(255,255,255,0.85); line-height:1.6; max-width:520px; margin-bottom:40px; font-weight:300;">
          Más de 40 años de ciencia forense al servicio de las familias. El primer paso es saber cómo empezar.
        </p>
        <a href="#guia"
          style="font-family:'Saira Condensed',sans-serif; font-size:16px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#E2064A; background:#fff; padding:14px 36px; text-decoration:none; display:inline-block;">
          DESCARGAR GUÍA GRATUITA →
        </a>
      </div>
    </div>
  </section>


  <!-- ▸ TRES PILARES -->
  <section style="background:#fff; padding:72px 24px; border-bottom:1px solid #E3E3E3;">
    <div style="max-width:1100px; margin:0 auto;">
      <h2 style="font-size:clamp(32px,4vw,48px); font-weight:800; color:#1D1D1B; margin-bottom:8px; letter-spacing:0.02em;">POR QUÉ EL EAAF</h2>
      <p style="font-family:'Roboto',sans-serif; font-size:16px; color:#7A7A7A; margin-bottom:48px; max-width:500px; line-height:1.6;">
        Una organización científica e independiente. No respondemos al Estado. Respondemos a las familias.
      </p>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:0;">
        {[
          {
            num: "01",
            title: "Ciencia comprobada",
            text: "Genética forense, arqueología y antropología trabajando juntas. Resultados admitidos como prueba en tribunales de todo el mundo."
          },
          {
            num: "02",
            title: "Confidencialidad total",
            text: "Tus datos genéticos y personales no son compartidos con ningún organismo estatal o judicial sin tu consentimiento expreso."
          },
          {
            num: "03",
            title: "Sin costo para familias",
            text: "Todos nuestros servicios de búsqueda, análisis e identificación son completamente gratuitos para los familiares. Siempre."
          },
        ].map((item, i) => (
          <div style={`padding:40px 36px; border-left:${i===0?'none':'1px solid #E3E3E3'}; border-top:4px solid ${i===0?'#E2064A':'#E3E3E3'};`}>
            <p style="font-family:'Saira Condensed',sans-serif; font-size:40px; font-weight:800; color:#E2064A; line-height:1; margin-bottom:16px;">{item.num}</p>
            <h3 style="font-size:22px; font-weight:700; color:#1D1D1B; margin-bottom:12px; letter-spacing:0.05em;">{item.title}</h3>
            <p style="font-family:'Roboto',sans-serif; font-size:15px; color:#7A7A7A; line-height:1.65;">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ▸ ESTADÍSTICAS -->
  <section style="background:#1D1D1B; padding:56px 24px;">
    <div style="max-width:1100px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:0; text-align:center;">
      {[
        { num: "+1.000", label: "Personas identificadas" },
        { num: "1984", label: "Año de fundación" },
        { num: "65+", label: "Países de actuación" },
        { num: "100%", label: "Gratuito para familias" },
      ].map((stat, i) => (
        <div style={`padding:32px 24px; border-left:${i>0?'1px solid rgba(255,255,255,0.1)':'none'};`}>
          <p style="font-family:'Saira Condensed',sans-serif; font-size:52px; font-weight:800; color:#E2064A; line-height:1; margin-bottom:8px;">{stat.num}</p>
          <p style="font-family:'Roboto',sans-serif; font-size:13px; color:rgba(255,255,255,0.6); text-transform:uppercase; letter-spacing:0.08em;">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>


  <!-- ▸ TESTIMONIO -->
  <section style="background:#fff; padding:80px 24px; border-bottom:1px solid #E3E3E3;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="border-left:5px solid #E2064A; padding-left:36px;">
        <p style="font-family:'Roboto',sans-serif; font-size:clamp(20px,2.5vw,26px); font-style:italic; color:#1D1D1B; line-height:1.55; margin-bottom:24px; font-weight:300;">
          "Cuando me llamaron para decirme que habían encontrado a mi hermano, me di cuenta de que la espera de 47 años no fue en vano. El EAAF me devolvió algo que creí perdido para siempre: la verdad."
        </p>
        <p style="font-family:'Saira Condensed',sans-serif; font-size:14px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#E2064A;">
          FAMILIAR DE DETENIDO-DESAPARECIDO — BUENOS AIRES
        </p>
      </div>
    </div>
  </section>


  <!-- ▸ LEAD MAGNET + FORMULARIO -->
  <section id="guia" style="background:#F8F8F8; padding:80px 24px; border-bottom:1px solid #E3E3E3;">
    <div style="max-width:1100px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start;">

      <div>
        <p style="font-family:'Saira Condensed',sans-serif; font-size:12px; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:#E2064A; margin-bottom:12px;">RECURSO GRATUITO</p>
        <h2 style="font-size:clamp(28px,3.5vw,44px); font-weight:800; color:#1D1D1B; margin-bottom:20px; line-height:1.05; letter-spacing:0.02em;">
          GUÍA: LOS PRIMEROS PASOS PARA REGISTRAR TU CASO
        </h2>
        <p style="font-family:'Roboto',sans-serif; font-size:16px; color:#7A7A7A; line-height:1.65; margin-bottom:36px;">
          Sabemos que dar el primer paso es lo más difícil. Esta guía explica en lenguaje claro todo lo que necesitás saber antes de contactarnos.
        </p>

        <p style="font-family:'Saira Condensed',sans-serif; font-size:12px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#54595F; margin-bottom:20px;">LO QUE ENCONTRARÁS ADENTRO:</p>
        <ul style="list-style:none; display:flex; flex-direction:column; gap:12px;">
          {[
            "Qué información reunir antes de dar una muestra de ADN",
            "Cómo funciona el proceso de identificación genética paso a paso",
            "Tus derechos como familiar: qué podés pedir y qué esperar",
            "Dónde y cómo actualizar el expediente de tu ser querido",
            "Preguntas frecuentes respondidas por nuestro equipo científico",
            "Recursos de acompañamiento psicológico disponibles",
          ].map(item => (
            <li style="display:flex; gap:12px; font-family:'Roboto',sans-serif; font-size:15px; color:#54595F; line-height:1.5;">
              <span style="color:#E2064A; font-weight:700; flex-shrink:0;">—</span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Formulario -->
      <div style="background:#fff; border-top:4px solid #E2064A; padding:40px; box-shadow:0 2px 20px rgba(0,0,0,0.06);">
        <h3 style="font-size:26px; font-weight:700; color:#1D1D1B; margin-bottom:4px; letter-spacing:0.05em;">RECIBIR LA GUÍA</h3>
        <p style="font-family:'Roboto',sans-serif; font-size:13px; color:#ADADAD; margin-bottom:32px;">Acceso inmediato · Sin spam · Completamente gratuita</p>

        <form style="display:flex; flex-direction:column; gap:18px;" onsubmit="return false;">
          <div>
            <label style="display:block; font-family:'Saira Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#54595F; margin-bottom:6px;">Nombre completo</label>
            <input type="text" placeholder="Ej: María González"
              style="width:100%; border:1px solid #D9D9D9; padding:12px 14px; font-size:14px; background:#F8F8F8;" />
          </div>
          <div>
            <label style="display:block; font-family:'Saira Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#54595F; margin-bottom:6px;">Correo electrónico</label>
            <input type="email" placeholder="tu@email.com"
              style="width:100%; border:1px solid #D9D9D9; padding:12px 14px; font-size:14px; background:#F8F8F8;" />
          </div>
          <div>
            <label style="display:block; font-family:'Saira Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#54595F; margin-bottom:6px;">País</label>
            <select style="width:100%; border:1px solid #D9D9D9; padding:12px 14px; font-size:14px; background:#F8F8F8; appearance:none;">
              <option value="">Seleccionar país</option>
              <option>Argentina</option><option>México</option><option>Chile</option>
              <option>Uruguay</option><option>Bolivia</option><option>Perú</option>
              <option>España</option><option>Otro</option>
            </select>
          </div>
          <div>
            <label style="display:block; font-family:'Saira Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#54595F; margin-bottom:6px;">Vínculo con la persona buscada</label>
            <select style="width:100%; border:1px solid #D9D9D9; padding:12px 14px; font-size:14px; background:#F8F8F8; appearance:none;">
              <option value="">Seleccionar vínculo</option>
              <option>Hijo/a</option><option>Padre / Madre</option><option>Hermano/a</option>
              <option>Cónyuge / Pareja</option><option>Nieto/a</option><option>Otro</option>
            </select>
          </div>
          <button type="submit"
            style="background:#E2064A; color:#fff; font-family:'Saira Condensed',sans-serif; font-size:16px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:16px; border:none; cursor:pointer; margin-top:8px;">
            ENVIAR Y DESCARGAR GRATIS →
          </button>
        </form>

        <p style="font-family:'Roboto',sans-serif; text-align:center; font-size:12px; color:#ADADAD; margin-top:16px; line-height:1.5;">
          Tu información es confidencial y nunca será compartida con terceros.
        </p>
      </div>
    </div>
  </section>


  <!-- ▸ FOOTER -->
  <footer style="background:#E2064A; padding:48px 24px 32px;">
    <div style="max-width:1100px; margin:0 auto;">
      <div style="display:grid; grid-template-columns:2fr 1fr 1fr; gap:48px; margin-bottom:40px;">
        <div>
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px;">
            <div style="border:2px solid rgba(255,255,255,0.6); padding:4px 8px;">
              <span style="font-family:'Saira Condensed',sans-serif; font-size:18px; font-weight:800; color:#fff; letter-spacing:0.08em;">EAAF</span>
            </div>
          </div>
          <p style="font-family:'Roboto',sans-serif; font-size:14px; color:rgba(255,255,255,0.8); line-height:1.65; max-width:280px; margin-bottom:20px;">
            Equipo Argentino de Antropología Forense. Organización científica no gubernamental dedicada a la búsqueda e identificación de personas desaparecidas.
          </p>
          <div style="display:flex; gap:16px;">
            {[
              { href: "https://www.facebook.com/EAAFoficial", svg: '<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>' },
              { href: "https://www.instagram.com/eaafoficial", svg: '<rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>', stroke: true },
              { href: "https://www.youtube.com/c/EAAFoficial", svg: '<path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>' },
            ].map(s => (
              <a href={s.href} target="_blank" rel="noopener" style="color:rgba(255,255,255,0.7);">
                <svg width="20" height="20" fill={s.stroke?"none":"currentColor"} stroke={s.stroke?"currentColor":"none"} stroke-width={s.stroke?"1.8":"0"} viewBox="0 0 24 24">
                  <Fragment set:html={s.svg} />
                </svg>
              </a>
            ))}
          </div>
        </div>

        <div>
          <p style="font-family:'Saira Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#fff; margin-bottom:16px;">SEDE CENTRAL</p>
          <p style="font-family:'Roboto',sans-serif; font-size:13px; color:rgba(255,255,255,0.75); line-height:1.8;">
            Espacio Memoria<br/>y Derechos Humanos<br/>Buenos Aires, Argentina<br/>info@eaaf.org
          </p>
        </div>

        <div>
          <p style="font-family:'Saira Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#fff; margin-bottom:16px;">OFICINAS</p>
          <p style="font-family:'Roboto',sans-serif; font-size:13px; color:rgba(255,255,255,0.75); line-height:1.8;">
            Nueva York, EE.UU.<br/>Ciudad de México, México<br/>Córdoba, Argentina<br/>Pretoria, Sudáfrica
          </p>
        </div>
      </div>

      <div style="border-top:1px solid rgba(255,255,255,0.2); padding-top:24px;">
        <p style="font-family:'Roboto',sans-serif; font-size:12px; color:rgba(255,255,255,0.5);">© 2026 EAAF — Organización científica no gubernamental sin fines de lucro</p>
      </div>
    </div>
  </footer>

</body>
</html>
